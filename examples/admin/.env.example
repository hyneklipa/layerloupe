# --- LayerLoupe configuration ---------------------------------------------
# Scenario: `admin` - login required, logged-in admin can delete.

# -- Access control ----------------------------------------------------
# Delete capability requires TWO flags both on:
#
#   1. AUTH_MODE=admin           - LayerLoupe exposes the trash icon and
#                                  lets the ``DELETE`` API call through
#                                  the auth guard.
#   2. REGISTRY_STORAGE_DELETE_ENABLED=true
#                                - the upstream registry actually
#                                  performs the unlink. Without this the
#                                  guard passes but the registry refuses
#                                  with ``MANIFEST_DELETE_DISABLED``.
#
# Both default to "on" in this example. Flip the registry flag to
# ``false`` if you want a login-required + read-only-but-with-audit
# trail kind of deploy.
AUTH_MODE=admin
REGISTRY_STORAGE_DELETE_ENABLED=true

# Admin identity. Regenerate the hash for your own password with:
#   uv run scripts/hash-password.py
# The hash below is bcrypt of "changeme" - DO NOT ship this as-is.
#
# IMPORTANT: wrap the hash in **single quotes**. Bcrypt hashes contain
# ``$`` characters that Docker Compose's .env parser would otherwise
# interpret as variable references (e.g. ``$DSx7LUQqLmu1vEiP`` →
# "variable not set" warning + truncated hash). Single quotes turn off
# interpolation for the value; double quotes don't help.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH='$2b$12$DSx7LUQqLmu1vEiP.txMqu2n5Uq3ap0qemmdN7HCC4DF/2Dx.JehC'

# -- Sessions ----------------------------------------------------------
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-only-replace-in-production

# -- Audit -------------------------------------------------------------
# Every successful delete writes one JSONL line here in addition to
# stdout. Mount this path to a host volume to keep it across container
# restarts.
AUDIT_LOG_PATH=/var/log/layerloupe/audit.log

# -- Logging -----------------------------------------------------------
LOG_JSON=false
LOG_LEVEL=info
