# --- LayerLoupe configuration ---------------------------------------------
# Scenario: `protected` — login required, read-only after login.
# Copy this file to `.env` next to the compose file before bringing the
# stack up.

# -- Access control ----------------------------------------------------
AUTH_MODE=protected

# Admin identity. The login form at /login will check these. The hash
# below is bcrypt of "changeme" — regenerate yours with:
#   uv run scripts/hash-password.py
#
# IMPORTANT: bcrypt hashes contain ``$`` characters, which Docker Compose
# would treat as variable references inside ``.env``. Wrap the hash in
# **single quotes** — Compose's .env parser skips interpolation for
# single-quoted values. (Double quotes won't help.)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH='$2b$12$DSx7LUQqLmu1vEiP.txMqu2n5Uq3ap0qemmdN7HCC4DF/2Dx.JehC'

# -- Sessions ----------------------------------------------------------
# Set this in production so sessions survive container restarts. Generate
# with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=dev-only-replace-in-production

# -- Logging -----------------------------------------------------------
LOG_JSON=false
LOG_LEVEL=info
