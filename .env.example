# --- LayerLoupe configuration ---------------------------------------------
# Copy to `.env` and edit. All variables are optional unless noted.

# -- Registry connection -----------------------------------------------
# Full URL of the registry to browse.
REGISTRY_URL=https://localhost:5000

# URL shown in `docker pull` commands. Defaults to REGISTRY_URL.
# REGISTRY_PUBLIC_URL=https://registry.example.com

# Verify TLS certs (set to `false` for self-signed).
SSL_VERIFY=true

# -- Registry authentication (optional) --------------------------------
# REGISTRY_USERNAME=
# REGISTRY_PASSWORD=

# Allow each user to log in via the UI (overrides global creds per session).
ALLOW_REGISTRY_LOGIN=false

# Show the delete-tag/manifest button. Registry must also allow deletes.
ALLOW_DELETE=false

# -- UI auth (basic auth in front of LayerLoupe) --------------------------
# UI_USERNAME=admin
# UI_PASSWORD=changeme

# -- Branding & sessions -----------------------------------------------
TITLE=LayerLoupe

# Session signing secret — set this in production!
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# SESSION_SECRET=

# -- Logging -----------------------------------------------------------
LOG_LEVEL=info
LOG_JSON=false

# -- Performance -------------------------------------------------------
# TTL (seconds) for cached registry responses. 0 disables caching.
CACHE_TTL=30

# Page size for /v2/_catalog and /v2/<repo>/tags/list.
PAGE_SIZE=100
