# --- LayerLoupe configuration ---------------------------------------------
# Copy to `.env` and edit. All variables are optional unless noted.

# -- Registry connection -----------------------------------------------
# Full URL of the registry to browse.
REGISTRY_URL=https://localhost:5000

# URL shown in `docker pull` commands. Defaults to REGISTRY_URL.
# REGISTRY_PUBLIC_URL=https://registry.example.com

# Verify TLS certs (set to `false` for self-signed).
SSL_VERIFY=true

# -- Registry authentication (optional) --------------------------------
# Global credentials used for every upstream registry call.
# REGISTRY_USERNAME=
# REGISTRY_PASSWORD=

# Allow each user to log in via the UI with their own registry creds
# (orthogonal to AUTH_MODE — survives UI logout).
ALLOW_REGISTRY_LOGIN=false

# -- UI access control -------------------------------------------------
# `public` (default): anonymous read-only browse, no delete.
# `protected`: login required for any page, still no delete.
# `admin`: login required, logged-in user can delete tags / manifests.
# See examples/ for runnable scenarios.
AUTH_MODE=public

# Admin identity (required when AUTH_MODE != public).
# ADMIN_USERNAME=admin
# Bcrypt hash of the admin password. Generate with:
#   uv run scripts/hash-password.py
#
# IMPORTANT: when using this in a Docker Compose ``.env`` file, wrap the
# hash in single quotes — the ``$`` characters in a bcrypt hash would
# otherwise be parsed as variable references. Single quotes disable
# interpolation; double quotes don't.
#   ADMIN_PASSWORD_HASH='$2b$12$...'
# ADMIN_PASSWORD_HASH=

# *_FILE alternatives for Docker / K8s secrets. The file is read as
# plaintext (the trust boundary is the file mount). When both _HASH
# and _FILE are set, the file value wins and a warning is logged.
# ADMIN_USERNAME_FILE=/run/secrets/layerloupe_admin_username
# ADMIN_PASSWORD_FILE=/run/secrets/layerloupe_admin_password

# -- Branding & sessions -----------------------------------------------
TITLE=LayerLoupe

# Session signing secret — set this in production!
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# SESSION_SECRET=

# Or load from a file (Docker / K8s secrets idiom):
# SESSION_SECRET_FILE=/run/secrets/layerloupe_session_secret

# -- Logging -----------------------------------------------------------
LOG_LEVEL=info
LOG_JSON=false

# -- Performance -------------------------------------------------------
# TTL (seconds) for cached registry responses. 0 disables caching.
CACHE_TTL=30

# Page size for /v2/_catalog and /v2/<repo>/tags/list.
PAGE_SIZE=100

# -- Audit -------------------------------------------------------------
# Optional JSONL audit file path. Every successful delete appends one
# line with actor, repo, reference, resolved digest, and timestamp.
# AUDIT_LOG_PATH=/var/log/layerloupe/audit.log
